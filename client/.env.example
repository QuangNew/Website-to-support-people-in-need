# ═══════════════════════════════════════════
#  RELIEF CONNECT — Frontend Environment Variables
#  Copy this file to .env and fill in the values
# ═══════════════════════════════════════════

# Backend API URL (default: ASP.NET Core dev server)
VITE_API_URL=http://localhost:5164/api

# No map API key needed — uses OpenStreetMap (free, no key required)

# Google OAuth Client ID (from Google Cloud Console)
# Leave empty to disable Google Sign-In
VITE_GOOGLE_CLIENT_ID=

# Supabase (for Storage – avatars & post images)
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=
